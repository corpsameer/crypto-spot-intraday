APP_NAME="Crypto Spot Intraday"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/cryptospot

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crypto_spot_intraday
